{
  "name": "claude-skills-panel",
  "displayName": "Claude Code Skills Panel",
  "description": "The fastest way to use Claude Code slash commands. Auto-discovers every /command, /skill, and installed plugin (superpowers, code-review, …). One click to copy or run. Aliases, custom groups, Quick Bar (keys 1–6), achievements, themes, fuzzy search. English · 한국어 · 日本語 · 中文.",
  "version": "0.32.0",
  "publisher": "parksubeom",
  "license": "MIT",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/parksubeom/claude-skills-panel.git"
  },
  "bugs": {
    "url": "https://github.com/parksubeom/claude-skills-panel/issues"
  },
  "homepage": "https://github.com/parksubeom/claude-skills-panel#readme",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Visualization",
    "Keymaps"
  ],
  "keywords": [
    "claude",
    "claude-code",
    "claude-code-plugin",
    "claude-code-plugins",
    "skills",
    "ai",
    "anthropic",
    "slash-commands",
    "slash-command",
    "command-palette",
    "command-launcher",
    "superpowers",
    "mcp",
    "ai-coding",
    "pixel-art",
    "8-bit",
    "retro",
    "gamification",
    "cursor",
    "productivity",
    "dotfiles",
    "developer-experience",
    "developer-tools",
    "agent",
    "agents",
    "i18n",
    "中文",
    "한국어",
    "日本語"
  ],
  "galleryBanner": {
    "color": "#0f172a",
    "theme": "dark"
  },
  "badges": [
    {
      "url": "https://img.shields.io/open-vsx/dt/parksubeom/claude-skills-panel?style=flat-square&label=Downloads&color=22c55e",
      "href": "https://open-vsx.org/extension/parksubeom/claude-skills-panel",
      "description": "OpenVSX downloads"
    },
    {
      "url": "https://img.shields.io/github/stars/parksubeom/claude-skills-panel?style=flat-square&color=fbbf24&logo=github",
      "href": "https://github.com/parksubeom/claude-skills-panel",
      "description": "GitHub stars"
    },
    {
      "url": "https://img.shields.io/badge/license-MIT-22c55e?style=flat-square",
      "href": "https://github.com/parksubeom/claude-skills-panel/blob/main/LICENSE",
      "description": "MIT License"
    }
  ],
  "qna": "https://github.com/parksubeom/claude-skills-panel/issues",
  "pricing": "Free",
  "sponsor": {
    "url": "https://github.com/parksubeom"
  },
  "main": "./extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "claudeSkillsSidebar",
          "title": "Claude Skills",
          "icon": "activity-icon.svg"
        }
      ],
      "panel": [
        {
          "id": "claudeSkillsPanel",
          "title": "Claude Skills",
          "icon": "activity-icon.svg"
        }
      ]
    },
    "views": {
      "claudeSkillsSidebar": [
        {
          "id": "claudeSkillsGridSidebar",
          "name": "Skills",
          "type": "webview"
        }
      ],
      "claudeSkillsPanel": [
        {
          "id": "claudeSkillsGridPanel",
          "name": "Skills",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "claudeSkills.refresh",
        "title": "Refresh Claude Skills",
        "icon": "$(refresh)"
      },
      {
        "command": "claudeSkills.show",
        "title": "Show Claude Skills Panel"
      },
      {
        "command": "claudeSkills.openConfig",
        "title": "Open Claude Skills Config"
      },
      { "command": "claudeSkills.quickSlot1", "title": "Claude Skills: Quick Slot 1" },
      { "command": "claudeSkills.quickSlot2", "title": "Claude Skills: Quick Slot 2" },
      { "command": "claudeSkills.quickSlot3", "title": "Claude Skills: Quick Slot 3" },
      { "command": "claudeSkills.quickSlot4", "title": "Claude Skills: Quick Slot 4" },
      { "command": "claudeSkills.quickSlot5", "title": "Claude Skills: Quick Slot 5" },
      { "command": "claudeSkills.quickSlot6", "title": "Claude Skills: Quick Slot 6" },
      { "command": "claudeSkills.showAchievements", "title": "Claude Skills: Show Achievements" },
      { "command": "claudeSkills.showWeeklyReport", "title": "Claude Skills: Show Weekly Report" }
    ],
    "menus": {
      "view/title": [
        {
          "command": "claudeSkills.refresh",
          "when": "view == claudeSkillsGridSidebar || view == claudeSkillsGridPanel",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "build:icon": "node scripts/build-icon.js",
    "build:pixels": "node scripts/build-pixel-icons.js",
    "build:spark": "node scripts/build-spark-icons.js",
    "build:buddy": "node scripts/build-buddy-icons.js && node scripts/build-buddy-classes.js",
    "verify": "node scripts/check-i18n.js && node -c extension.js && node -c userConfig.js && node -c achievements.js && node -c iconMap.js && node -c i18n/strings.js",
    "package": "npm run verify && npm run build:pixels && npm run build:spark && npm run build:buddy && vsce package",
    "publish:vsce": "vsce publish",
    "publish:ovsx": "ovsx publish",
    "publish:all": "npm run package && vsce publish && ovsx publish"
  },
  "type": "commonjs",
  "devDependencies": {
    "@vscode/vsce": "^3.2.0",
    "ovsx": "^0.10.0",
    "sharp": "^0.34.5"
  }
}
