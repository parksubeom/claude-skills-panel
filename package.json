{
  "name": "claude-skills-panel",
  "displayName": "Claude Code Skills Panel",
  "description": "Browse and trigger Claude Code skills from a bottom panel grid",
  "version": "0.4.1",
  "publisher": "codnut00",
  "license": "MIT",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/parksubeom/claude-skills-panel.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "claude",
    "claude-code",
    "skills",
    "ai"
  ],
  "main": "./extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "claudeSkillsSidebar",
          "title": "Claude Skills",
          "icon": "icon.svg"
        }
      ],
      "panel": [
        {
          "id": "claudeSkillsPanel",
          "title": "Claude Skills",
          "icon": "icon.svg"
        }
      ]
    },
    "views": {
      "claudeSkillsSidebar": [
        {
          "id": "claudeSkillsGridSidebar",
          "name": "Skills",
          "type": "webview"
        }
      ],
      "claudeSkillsPanel": [
        {
          "id": "claudeSkillsGridPanel",
          "name": "Skills",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "claudeSkills.refresh",
        "title": "Refresh Claude Skills",
        "icon": "$(refresh)"
      },
      {
        "command": "claudeSkills.show",
        "title": "Show Claude Skills Panel"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "claudeSkills.refresh",
          "when": "view == claudeSkillsGridSidebar || view == claudeSkillsGridPanel",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "build:icon": "node scripts/build-icon.js",
    "build:pixels": "node scripts/build-pixel-icons.js",
    "package": "npm run build:pixels && vsce package",
    "publish:vsce": "vsce publish",
    "publish:ovsx": "ovsx publish",
    "publish:all": "npm run package && vsce publish && ovsx publish"
  },
  "type": "commonjs",
  "devDependencies": {
    "@vscode/vsce": "^3.2.0",
    "ovsx": "^0.10.0",
    "sharp": "^0.34.5"
  }
}
